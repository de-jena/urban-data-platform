-library: enableOSGi-Test
-runrequires.engine: \
	bnd.identity;id='junit-jupiter-engine',\
	bnd.identity;id='junit-platform-launcher'

-resolve.effective: active

-runrequires: \
	bnd.identity;id='de.dim.trafficos.publictransport.api.mmt.tests',\
	bnd.identity;id='de.dim.trafficos.publictransport.api.mmt'
	
-runblacklist: \
	bnd.identity;id='org.gecko.emf.osgi.api';version='[4,5)',\
	bnd.identity;id='org.gecko.emf.osgi.component';version='[4,5)',\

-runfw: org.apache.felix.framework;version='[7.0.5,7.0.5]'
-runee: JavaSE-25
-runvm: --enable-native-access=ALL-UNNAMED
-runproperties: org.apache.lucene.store.MMapDirectory.enableMemorySegments=false
-runbundles: \
	de.dim.trafficos.publictransport.api.mmt;version=snapshot,\
	de.dim.trafficos.publictransport.api.mmt.tests;version=snapshot,\
	lpg.runtime.java;version='[2.0.17,2.0.18)',\
	org.apache.felix.configadmin;version='[1.9.26,1.9.27)',\
	org.osgi.util.function;version='[1.2.0,1.2.1)',\
	org.osgi.util.promise;version='[1.3.0,1.3.1)',\
	de.jena.udp.trafficos.common.model;version='[1.2.0,1.2.1)',\
	de.jena.udp.trafficos.publictransport.api.model;version='[1.2.0,1.2.1)',\
	de.jena.udp.trafficos.publictransport.model;version='[1.2.0,1.2.1)',\
	org.apache.felix.cm.json;version='[2.0.0,2.0.1)',\
	org.apache.felix.configurator;version='[1.0.18,1.0.19)',\
	org.eclipse.emf.ecore.change;version='[2.15.0,2.15.1)',\
	org.eclipse.parsson.jakarta.json;version='[1.1.5,1.1.6)',\
	org.opentest4j;version='[1.3.0,1.3.1)',\
	org.osgi.service.component;version='[1.5.1,1.5.2)',\
	org.osgi.service.log;version='[1.5.0,1.5.1)',\
	org.osgi.util.converter;version='[1.0.9,1.0.10)',\
	org.apache.felix.scr;version='[2.2.12,2.2.13)',\
	org.eclipse.equinox.supplement;version='[1.11.100,1.11.101)',\
	org.eclipse.fennec.qvt.component;version='[1.1.0,1.1.1)',\
	org.eclipse.m2m.qvt.oml;version='[1.0.0,1.0.1)',\
	org.eclipse.m2m.qvt.oml.common;version='[1.0.0,1.0.1)',\
	org.eclipse.m2m.qvt.oml.cst.parser;version='[1.0.0,1.0.1)',\
	org.eclipse.m2m.qvt.oml.ecore.imperativeocl;version='[1.0.0,1.0.1)',\
	org.eclipse.m2m.qvt.oml.emf.util;version='[1.0.0,1.0.1)',\
	org.eclipse.m2m.qvt.oml.ocl;version='[1.0.0,1.0.1)',\
	org.eclipse.ocl;version='[1.0.0,1.0.1)',\
	org.eclipse.ocl.common;version='[1.0.0,1.0.1)',\
	org.eclipse.ocl.ecore;version='[1.0.0,1.0.1)',\
	org.gecko.emf.osgi.component.minimal;version='[6.3.0,6.3.1)',\
	assertj-core;version='[3.26.3,3.26.4)',\
	net.bytebuddy.byte-buddy;version='[1.14.18,1.14.19)',\
	org.osgi.test.common;version='[1.3.0,1.3.1)',\
	org.osgi.test.junit5;version='[1.3.0,1.3.1)',\
	org.osgi.test.junit5.cm;version='[1.3.0,1.3.1)',\
	junit-jupiter-api;version='[5.14.2,5.14.3)',\
	junit-jupiter-engine;version='[5.14.2,5.14.3)',\
	junit-jupiter-params;version='[5.14.2,5.14.3)',\
	junit-platform-commons;version='[1.14.2,1.14.3)',\
	junit-platform-engine;version='[1.14.2,1.14.3)',\
	junit-platform-launcher;version='[1.14.2,1.14.3)',\
	org.eclipse.emf.common;version='[2.44.0,2.44.1)',\
