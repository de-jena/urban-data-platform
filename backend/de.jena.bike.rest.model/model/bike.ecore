    <eOperations name="ValidationJobCreate" eType="ecore:EClass bike.ecore#//Response">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Validate the data of the given sites from their ids on a period. The process is asynchronous.&#xA;Restrictions:&#xA;- Only one job can be in progress per API key&#xA;- The validation period cannot exceed 1 year&#xA;- Maximum 10 sites can be validated at once&#xA; endpoint: /validation/data/jobs"/>
      </eAnnotations>
      <eParameters name="request" eType="ecore:EClass bike.ecore#//ValidationJobCreate_request"/>
    </eOperations>
